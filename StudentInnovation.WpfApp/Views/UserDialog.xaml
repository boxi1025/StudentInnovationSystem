<Window x:Class="StudentInnovation.WpfApp.Views.UserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="添加/编辑用户" Height="600" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Height" Value="28"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Height" Value="28"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 标题 -->
        <TextBlock Text="用户信息" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,20"
                   HorizontalAlignment="Center"/>

        <!-- 左侧列：账户信息 -->
        <Border Grid.Row="1" Grid.Column="0"
                BorderBrush="#E0E0E0" BorderThickness="1"
                CornerRadius="6" Padding="16">
            <StackPanel>
                <TextBlock Text="账户信息" FontSize="16" FontWeight="Bold" Margin="0,0,0,16"/>

                <TextBlock Text="用户名"/>
                <TextBox x:Name="UsernameTextBox"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="密码"/>
                <TextBox x:Name="PasswordTextBox"
                         Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="确认密码"/>
                <TextBox x:Name="ConfirmPasswordTextBox"
                         Text="{Binding ConfirmPassword, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </Border>

        <!-- 右侧列：个人信息 -->
        <Border Grid.Row="1" Grid.Column="2"
                BorderBrush="#E0E0E0" BorderThickness="1"
                CornerRadius="6" Padding="16">
            <StackPanel>
                <TextBlock Text="个人信息" FontSize="16" FontWeight="Bold" Margin="0,0,0,16"/>

                <TextBlock Text="角色"/>
                <ComboBox SelectedValue="{Binding Role}" SelectedValuePath="Content">
                    <ComboBoxItem Content="Teacher"/>
                    <ComboBoxItem Content="Student"/>
                </ComboBox>

                <TextBlock Text="姓名"/>
                <TextBox x:Name="FullNameTextBox"
                         Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="学院"/>
                <TextBox x:Name="DepartmentTextBox"
                         Text="{Binding Department, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
        </Border>

        <!-- 学号/工号区域 -->
        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                BorderBrush="#E0E0E0" BorderThickness="1"
                CornerRadius="6" Padding="16" Margin="0,16,0,16">
            <StackPanel>
                <TextBlock Text="身份信息" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="学号：" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="StudentNoTextBox" Grid.Row="0" Grid.Column="1"
                             Text="{Binding StudentNo, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsStudent}" />

                    <TextBlock Text="工号：" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,8,8,0"/>
                    <TextBox x:Name="EmployeeNoTextBox" Grid.Row="1" Grid.Column="1"
                             Text="{Binding EmployeeNo, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsTeacher}" Margin="0,8,0,0"/>
                </Grid>

                <TextBlock Text="提示：学生请填写学号，教师请填写工号。"
                           FontStyle="Italic" Foreground="#666666" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- 按钮区域 -->
        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                    Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="确定" x:Name="OkButton" Click="OkButton_Click" IsDefault="True"/>
            <Button Content="取消" x:Name="CancelButton" Click="CancelButton_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>