<Window x:Class="StudentInnovation.WpfApp.Views.RejectReasonDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="输入驳回理由" Height="240" Width="420" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Background="{StaticResource PageBackgroundBrush}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="请填写驳回理由（学生可见）" FontWeight="SemiBold" Foreground="{StaticResource AccentTextBrush}" Margin="0,0,0,8"/>
        <TextBox x:Name="ReasonBox" Grid.Row="1" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="取消" Margin="0,0,8,0" Style="{StaticResource SecondaryButtonStyle}" Click="Cancel_Click"/>
            <Button Content="确定驳回" Style="{StaticResource PrimaryButtonStyle}" Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>
